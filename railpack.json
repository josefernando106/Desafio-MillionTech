{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": ["cd backend && npm install"]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": ["cd backend && npm run build"]
    }
  },
  "deploy": {
    "startCommand": "node backend/dist/server.js"
  }
}
