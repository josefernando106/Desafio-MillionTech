{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": ["docker-compose up --build"]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": ["./my-custom-build.sh"]
    }
  },
  "deploy": {
    "startCommand": "node dist/index.js"
  }
}